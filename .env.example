# MaxxAir Fan Pi Interface — copy to .env and edit
# Full reference: docs/configuration.md

# Firebase Realtime Database
FIREBASE_URL=https://your-project-rtdb.firebaseio.com
FIREBASE_SECRET=your_database_secret

# Fan node path in Firebase
FAN_NODE=fans/fan1

# IR code directory (defaults to ./ir_codes in repo)
# IR_DIR=/home/pi/maxxair-fan-pi-interface/ir_codes

# DS18B20 sensor path (auto-detects first 28-* device if unset)
# SENSOR_PATH=/sys/bus/w1/devices/28-000000c0959a/w1_slave

# Control loop interval in seconds (2 recommended for DS18B20 conversion time)
CHECK_INTERVAL=2

# Fan speed curve tuning (Ryder Henry's exponential algorithm)
GRADIENT_DEGREES=0.5
EXPONENT_VALUE=2.0

# Firebase write throttling
TEMP_PATCH_THRESHOLD=0.1
PATCH_HEARTBEAT_SECONDS=60

# Send fan_off.ir on graceful shutdown
FAN_OFF_ON_EXIT=false

# Single-instance lock file
LOCK_FILE=/tmp/maxxair-fan.lock

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Skip startup preflight checks (not recommended on Pi)
# MAXXAIR_SKIP_PREFLIGHT=false

# Local development / simulator backends
# MAXXAIR_BACKEND=simulator
# SENSOR_BACKEND=fake
# IR_BACKEND=fake
# FIREBASE_BACKEND=memory
# FAKE_SENSOR_TEMP=72.0
# FAKE_IR_LOG=.dev/ir.log
